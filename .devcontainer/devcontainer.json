{
  "name": "Total Recall — Agent Harness Workshop",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  },
  "forwardPorts": [8000, 8888],
  "portsAttributes": {
    "8000": { "label": "Total Recall appbook", "onAutoForward": "openPreview" },
    "8888": { "label": "JupyterLab", "onAutoForward": "silent" }
  },
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "postStartCommand": "bash .devcontainer/start-app.sh",
  // Forward the OCI GenAI secrets from the Codespaces environment into the env that lifecycle
  // commands and terminals see, so the auto-started appbook gets the same keys the notebook does.
  // (docker-compose already injects these into the container; this also covers the lifecycle path.)
  "remoteEnv": {
    "OCI_GENAI_API_KEY": "${localEnv:OCI_GENAI_API_KEY}",
    "OCI_GENAI_API_KEY_2": "${localEnv:OCI_GENAI_API_KEY_2}",
    "OCI_GENAI_API_KEY_3": "${localEnv:OCI_GENAI_API_KEY_3}",
    "OCI_GENAI_API_KEY_4": "${localEnv:OCI_GENAI_API_KEY_4}"
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python", "ms-toolsai.jupyter", "bierner.markdown-mermaid"],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  }
}
